# Bun AI Agent Workspace root gitignore
# The real Bun project lives in bun_main/

# Generated build artifacts at workspace root
/build/
/target/
/tmp/
node_modules/

# Bun build artifacts inside bun_main (also covered by bun_main/.gitignore but explicit here)
/bun_main/build/
/bun_main/target/
/bun_main/tmp/
/bun_main/node_modules/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# AI / Claude local state
.claude/settings.local.json
.cursor/settings.local.json

# Misc
.env
.envrc
*.log
*.trace

# =============================================================================
# AI Agent Workspace-only files
# These files are specific to this AI contribution workspace setup.
# They should NOT be committed or included when sending PRs to the upstream Bun repository.
# The real source code lives in bun_main/, and changes there can be contributed normally.
# =============================================================================
AGENTS.md
CLAUDE.md
CONTRIBUTING.md
README.md
CODE_OF_CONDUCT.md
SECURITY.md
LICENSE.md

# Optional: uncomment if you want the local .claude/ skills to stay untracked too
# .claude/
