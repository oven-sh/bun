{
  "private": true,
  "name": "bun",
  "version": "1.4.0",
  "workspaces": [
    "./packages/bun-types",
    "./packages/@types/bun"
  ],
  "devDependencies": {
    "@lezer/common": "^1.2.3",
    "@lezer/cpp": "^1.1.3",
    "@types/bun": "workspace:*",
    "bun-tracestrings": "github:oven-sh/bun.report#912ca63e26c51429d3e6799aa2a6ab079b188fd8",
    "esbuild": "^0.21.5",
    "mitata": "^0.1.14",
    "oxlint": "1.70.0",
    "peechy": "0.4.34",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "source-map-js": "^1.2.1",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "bun-types": "workspace:packages/bun-types",
    "@types/bun": "workspace:packages/@types/bun",
    "@types/node": "25.0.0"
  },
  "scripts": {
    "build": "bun --silent run build:debug",
    "ci:find": "bun scripts/find-build.ts",
    "ci:status": "bun scripts/find-build.ts --status",
    "ci:errors": "bun scripts/find-build.ts --errors",
    "ci:logs": "bun scripts/find-build.ts --logs",
    "ci:watch": "bun scripts/find-build.ts --watch",
    "ci:slowest": "bun scripts/ci-slowest-tests.ts",
    "pr:comments": "bun scripts/pr-comments.ts",
    "watch": "cargo watch -x 'check --workspace --message-format=short'",
    "watch-windows": "cargo watch -x \"check --workspace --target x86_64-pc-windows-msvc --message-format=short\"",
    "bd:v": "bun scripts/build.ts --profile=debug",
    "bd": "BUN_DEBUG_QUIET_LOGS=1 bun scripts/build.ts --profile=debug --quiet",
    "build:debug": "bun scripts/build.ts --profile=debug",
    "build:debug:fuzzilli": "bun scripts/build.ts --profile=debug --fuzzilli=on --build-dir=build/debug-fuzz",
    "build:debug:noasan": "bun scripts/build.ts --profile=debug-no-asan",
    "build:release": "bun scripts/build.ts --profile=release",
    "build:release:lto": "bun scripts/build.ts --profile=release --lto=on --build-dir=build/release-lto",
    "build:btg": "bun scripts/build.ts --profile=btg",
    "build:ci": "bun scripts/build.ts --profile=ci-release --build-dir=build/release-ci",
    "build:assert": "bun scripts/build.ts --profile=release-assertions --build-dir=build/release-assert",
    "build:asan": "bun scripts/build.ts --profile=release-asan --build-dir=build/release-asan",
    "build:logs": "bun scripts/build.ts --profile=release --logs=on --build-dir=build/release-logs",
    "build:smol": "bun scripts/build.ts --profile=release --build-type=MinSizeRel --build-dir=build/release-smol",
    "build:local": "bun scripts/build.ts --profile=debug-local --build-dir=build/debug-local",
    "build:release:local": "bun scripts/build.ts --profile=release-local --build-dir=build/release-local",
    "run:linux": "docker run --rm  -v \"$PWD:/root/bun/\" -w /root/bun ghcr.io/oven-sh/bun-development-docker-image",
    "uv-posix-stubs": "bun run src/jsc/bindings/libuv/generate_uv_posix_stubs.ts",
    "bump": "bun ./scripts/bump.ts",
    "jsc:build": "bun scripts/build.ts --profile=release-local --build-dir=build/release-local --target=WebKit",
    "jsc:build:debug": "bun scripts/build.ts --profile=debug-local --build-dir=build/debug-local --target=WebKit",
    "jsc:build:lto": "bun scripts/build.ts --profile=release-local --lto=on --build-dir=build/release-local-lto --target=WebKit",
    "typecheck": "tsc --noEmit && cd test && bun run typecheck",
    "fmt": "bun run prettier",
    "fmt:cpp": "bun run clang-format",
    "fmt:rust": "cargo fmt --all",
    "lint": "oxlint --config=oxlint.json --format=github src/js",
    "lint:fix": "oxlint --config oxlint.json --fix",
    "test": "node scripts/runner.node.mjs --exec-path ./build/debug/bun-debug",
    "testleak": "BUN_DESTRUCT_VM_ON_EXIT=1 ASAN_OPTIONS=detect_leaks=1 LSAN_OPTIONS=malloc_context_size=100:print_suppressions=1:suppressions=$npm_config_local_prefix/test/leaksan.supp ./build/debug/bun-debug",
    "test:release": "node scripts/runner.node.mjs --exec-path ./build/release/bun",
    "rust:check": "cargo check --workspace --keep-going",
    "rust:check-all": "bun scripts/rust-check-all.ts",
    "rust:clippy": "cargo clippy --workspace --no-deps --keep-going",
    "rust:miri": "bun scripts/rust-miri.ts",
    "codegen:string-maps": "for f in src/**/*.string-map.ts; do bun src/codegen/generate-string-map.ts \"$f\" \"${f%.string-map.ts}.generated.rs\"; done",
    "codegen:verify": "bun run codegen:string-maps && git diff --exit-code 'src/**/*.generated.rs' || (echo '\\n*.generated.rs is stale — run `bun run codegen:string-maps` and commit the result.' >&2; exit 1)",
    "clang-format": "./scripts/run-clang-format.sh format",
    "clang-format:check": "./scripts/run-clang-format.sh check",
    "clang-format:diff": "./scripts/run-clang-format.sh diff",
    "prettier": "bun --bun ./node_modules/.bin/prettier --plugin=prettier-plugin-organize-imports --config .prettierrc --write scripts packages src docs 'test/**/*.{test,spec}.{ts,tsx,js,jsx,mts,mjs,cjs,cts}' '!test/**/*fixture*.*'",
    "node:test": "node ./scripts/runner.node.mjs --quiet --exec-path=$npm_execpath --node-tests ",
    "node:test:cp": "bun ./scripts/fetch-node-test.ts ",
    "clean": "bun scripts/build/clean.ts",
    "machine:linux:ubuntu": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=linux --distro=ubuntu --release=25.04",
    "machine:linux:debian": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=linux --distro=debian --release=13",
    "machine:linux:alpine": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=linux --distro=alpine --release=3.22",
    "machine:linux:amazonlinux": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=linux --distro=amazonlinux --release=2023",
    "machine:windows:2019": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=windows --release=2019",
    "machine:freebsd": "./scripts/machine.mjs ssh --cloud=aws --arch=x64 --instance-type c7i.2xlarge --os=freebsd --release=14.3",
    "sync-webkit-source": "bun ./scripts/sync-webkit-source.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@remix-run/serve": "^2.17.4",
    "@testing-library/jest-dom": "^6.9.1",
    "astro": "^6.4.2",
    "comlink": "^4.4.2",
    "decompress": "4.2.1",
    "detect-libc": "^2.1.2",
    "fast-glob": "^3.3.3",
    "fastify": "^5.8.5",
    "hono": "^4.12.23",
    "http2-wrapper": "^2.2.1",
    "immutable": "^5.1.6",
    "is-even": "^1.0.0",
    "jimp": "^1.6.1",
    "msgpackr-extract": "^3.0.4",
    "msw": "^2.14.6",
    "mysql2": "^3.22.4",
    "p-queue": "^9.3.0",
    "pg-gateway": "^0.3.0-beta.4",
    "proxy": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rollup": "^4.60.4",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "sinon": "^22.0.0",
    "socket.io-client": "^4.8.3",
    "solc": "^0.8.35",
    "st": "^3.0.3",
    "stripe": "^22.2.0",
    "supertest": "^7.2.2",
    "svelte": "^5.55.10",
    "unzipper": "^0.12.3",
    "v8-heapsnapshot": "^1.3.1",
    "verdaccio": "^6.7.2",
    "xml2js": "^0.6.2"
  }
}
