+// Fold `.`/`..` lexically. The OS resolves symlinks BEFORE `..`, so a checkout
+// whose vendor/ is a symlink would otherwise escape to the symlink target's
+// parent; the repo files live relative to the checkout root as spelled.
+fn lexical_normalize(path: &Path) -> PathBuf {
+    let mut parts: Vec<Component> = Vec::new();
+    for component in path.components() {
+        match component {
+            Component::CurDir => {}
+            Component::ParentDir if matches!(parts.last(), Some(Component::Normal(_))) => {
+                parts.pop();
+            }
+            other => parts.push(other),
+        }
     }
+    parts.iter().collect()
+}
 
