+// Numeric-aware sort key so "MacOSX26.5.sdk" beats "MacOSX9.0.sdk" and MSVC
+// "14.44.35207" beats "14.9.x".
+fn version_key(name: &str) -> Vec<u64> {
+    name.split(|c: char| !c.is_ascii_digit())
+        .filter(|s| !s.is_empty())
+        .map(|s| s.parse().unwrap_or(0))
+        .collect()
 }
 
