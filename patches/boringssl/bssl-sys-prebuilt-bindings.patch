+// Compiler builtin headers (stdarg.h, stddef.h, …) for the -nostdinc targets.
+fn clang_resource_include() -> PathBuf {
+    println!("cargo:rerun-if-env-changed=CLANG");
+    let clang = env::var("CLANG").unwrap_or_else(|_| "clang".into());
+    let output = Command::new(&clang)
+        .arg("-print-resource-dir")
+        .output()
+        .unwrap_or_else(|err| {
+            panic!(
+                "bssl-sys: failed to run `{} -print-resource-dir`: {}\n\
+                 note: clang provides the builtin headers bindgen needs for cross-target parsing; \
+                 install clang or set CLANG=<path-to-clang>",
+                clang, err
+            )
+        });
+    assert!(
+        output.status.success(),
+        "bssl-sys: `{clang} -print-resource-dir` failed: {}",
+        String::from_utf8_lossy(&output.stderr)
+    );
+    PathBuf::from(String::from_utf8_lossy(&output.stdout).trim()).join("include")
