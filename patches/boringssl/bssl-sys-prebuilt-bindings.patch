+// Hermetic libc headers from vendor/zig for linux/android/freebsd targets.
+// `family` is zig's per-arch dir prefix (x86 for x86_64-gnu — zig's glibc
+// headers use the x86 family dir; x86_64 for musl), `abi` the header set.
+fn zig_libc_args(args: &mut Vec<String>, zig_libc: &Path, family: &str, abi: &str, generic: &str) {
+    args.push("-nostdinc".into());
+    isystem(args, &clang_resource_include());
+    isystem(args, &zig_libc.join(format!("{family}-{abi}")));
+    isystem(args, &zig_libc.join(generic));
+    // The -any dirs don't exist for every family (e.g. no x86_64-linux-any);
+    // clang would ignore a missing -isystem, skip it to keep the args honest.
+    for extra in [format!("{family}-linux-any"), "any-linux-any".into()] {
+        let dir = zig_libc.join(&extra);
+        if dir.is_dir() {
+            isystem(args, &dir);
+        }
+    }
+}
