+int bssl::x509_check_cert_time_valid(const X509_STORE_CTX *ctx, const X509 *x) {
+  if (ctx->param->flags & X509_V_FLAG_NO_CHECK_TIME) {
+    return 1;
+  }
+
+  int64_t ptime;
+  if (ctx->param->flags & X509_V_FLAG_USE_CHECK_TIME) {
+    ptime = ctx->param->check_time;
+  } else {
+    ptime = time(nullptr);
+  }
+
+  // notBefore must be in the past and notAfter in the future. A zero return
+  // from |X509_cmp_time_posix| indicates an invalid time field, which is not
+  // "valid" for the purposes of preferring a candidate.
+  return X509_cmp_time_posix(X509_get0_notBefore(x), ptime) < 0 &&
+         X509_cmp_time_posix(X509_get0_notAfter(x), ptime) > 0;
+}
