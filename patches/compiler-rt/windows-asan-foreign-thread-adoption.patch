+#if SANITIZER_WINDOWS
+static AsanThread *AdoptCurrentThread() {
+  // AsanInited() flips before CreateMainThread() runs, so it is the wrong
+  // readiness signal: adopting inside that window steals the main thread
+  // from CreateMainThread. Wait until T0's bookkeeping is complete.
+  if (!AsanMainThreadCreated())
+    return nullptr;
+  // Threads created through the CreateThread interceptor are registered
+  // by asan_thread_start; adopting them from earlier CRT-trampoline code
+  // would race that registration. They are recognised at thread attach.
+  if (AsanThreadInterceptorOwned())
+    return nullptr;
+  // Re-entrancy guard: Create() allocates, and allocation consults
+  // GetCurrentThread(), which would re-enter here on this still-unregistered
+  // thread. Also serializes the OS-id lookup below.
+  static THREADLOCAL bool adopting;
+  if (adopting)
+    return nullptr;
+  adopting = true;
+  AsanThread *t = nullptr;
+  // Identity by OS thread id, not the TSD: on Windows the TSD is a
+  // __declspec(thread) slot masked to null until the TEB's TLS pointer is
+  // set, so a null AsanTSDGet() cannot distinguish "no thread" from "not
+  // visible yet". The registry knows every thread the runtime created
+  // (including an early main thread), so only a genuinely unknown OS
+  // thread -- e.g. a thread-pool worker started by ntdll's worker factory,
+  // which never passes through the intercepted CreateThread -- is adopted.
+  // The *Locked lookup requires the registry lock; scope it to the lookup
+  // alone, since AsanThread::Create() below registers the new thread and
+  // takes the same lock itself.
+  bool known;
+  {
+    ThreadRegistryLock l(&asanThreadRegistry());
+    known = GetAsanThreadByOsIDLocked(GetTid()) != nullptr;
+  }
+  if (!known) {
+    t = AsanThread::Create(kInvalidTid, /*stack=*/nullptr, /*detached=*/true);
+    if (t) {
+      SetCurrentThread(t);
+      t->ThreadStart(GetTid());
+    }
+  }
+  adopting = false;
+  return t;
+}
+#endif
