+// --- Foreign-thread adoption: distinguishing interceptor-owned threads ---
+// A thread created through the CreateThread interceptor is registered by
+// asan_thread_start (the trampoline the interceptor hands to CreateThread).
+// Code that runs on such a thread BEFORE the trampoline body -- the CRT's
+// per-thread startup -- can call GetCurrentThread() and would trigger lazy
+// adoption, racing the interceptor's own registration. At DLL_THREAD_ATTACH
+// (which runs on the new thread before that CRT startup) we identify these
+// threads by their Win32 start address and mark them so adoption defers.
+// Threads with any other start address (e.g. ntdll's thread-pool workers,
+// which start at TppWorkerThread) remain adoptable.
+// Classification is recorded in a process-wide table keyed by OS thread id,
+// deliberately NOT in a __declspec(thread) variable: the DLL_THREAD_ATTACH
+// callback runs before this DLL's TLS block is finalised for the new thread,
+// so a thread-local written there is not the instance later reads observe.
+// A small open-addressed table of (tid -> owned) is enough; thread ids are
+// recycled, and the entry is overwritten on the next attach with that id.
+namespace {
+struct TidClassEntry {
+  atomic_uint32_t tid;    // 0 = empty
+  atomic_uint8_t owned;   // 1 = created via the CreateThread interceptor
+};
+constexpr uptr kTidClassSlots = 1024;
+TidClassEntry tid_class_table[kTidClassSlots];
+}  // namespace
+
+static void RecordThreadClass(u32 tid, bool owned) {
+  uptr idx = tid % kTidClassSlots;
+  for (uptr n = 0; n < kTidClassSlots; ++n, idx = (idx + 1) % kTidClassSlots) {
+    u32 cur = atomic_load(&tid_class_table[idx].tid, memory_order_acquire);
+    if (cur == tid || cur == 0) {
+      atomic_store(&tid_class_table[idx].owned, owned ? 1 : 0,
+                   memory_order_release);
+      atomic_store(&tid_class_table[idx].tid, tid, memory_order_release);
+      return;
+    }
+  }
+}
+bool AsanThreadInterceptorOwned() {
+  u32 tid = (u32)GetTid();
+  uptr idx = tid % kTidClassSlots;
+  for (uptr n = 0; n < kTidClassSlots; ++n, idx = (idx + 1) % kTidClassSlots) {
+    u32 cur = atomic_load(&tid_class_table[idx].tid, memory_order_acquire);
+    if (cur == tid)
+      return atomic_load(&tid_class_table[idx].owned, memory_order_acquire) == 1;
+    if (cur == 0)
+      return false;
+  }
+  return false;
+}
