+			    ARCHIVE_ERRNO_MISC,
+			    "Truncated tar archive"
+			    " detected while skipping data");
+			return (ARCHIVE_FATAL);
+		}
+		if (avail > request)
+			avail = (ssize_t)request;
+		if (__archive_read_consume(a, avail) != avail)
+			return (ARCHIVE_FATAL);
+		request -= avail;
+	}
+	return (ARCHIVE_OK);
