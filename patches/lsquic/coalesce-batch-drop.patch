+                return_staged_packets(conn, packet_spec, packet);
+                packet = packet_spec;
+                iov = packet_iov;
                 LSQ_INFOC("conn %"CID_FMT" has unsendable packets",
                                         CID_BITS(lsquic_conn_log_cid(conn)));
                 if (!(conn->cn_flags & LSCONN_EVANESCENT))
@@ -2982,6 +3005,9 @@
             {
