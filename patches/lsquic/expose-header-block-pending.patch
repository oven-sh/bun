+/* Bun: a header block (interim 1xx or final) is still being sent when the
+ * send-headers state machine has not returned to SSHS_BEGIN. lsquic keeps a
+ * single sm_header_block slot, so a caller must not call
+ * lsquic_stream_send_headers() again until this returns 0 or the stashed
+ * block is overwritten. */
+int
+lsquic_stream_header_block_pending (const struct lsquic_stream *stream)
+{
+    return stream->sm_send_headers_state != SSHS_BEGIN;
+}
