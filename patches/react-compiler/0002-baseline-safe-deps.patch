Keep post-Nehalem instruction sets out of bun's baseline builds
(verify-baseline-static scans every emitted instruction):

- sha2 compiles a CPUID-dispatched SHA-NI block function by default.
  "force-soft" keeps it pure software; it only hashes short gating
  directive strings, so the hardware path is irrelevant.
--- a/compiler/crates/react_compiler_reactive_scopes/Cargo.toml
+++ b/compiler/crates/react_compiler_reactive_scopes/Cargo.toml
@@ -9,5 +9,5 @@
 react_compiler_hir = { path = "../react_compiler_hir" }
 indexmap = "2"
 serde_json = "1"
-sha2 = "0.10"
+sha2 = { version = "0.10", features = ["force-soft"] }
 hmac = "0.12"
