# lld --symbol-ordering-file
#
# Hot-startup symbol order for `bun <file>` / `bun .` / `bun run <script>` /
# `bun install` / `bun --version`. lld clusters listed symbols at the front
# of `.text`, packing all init-array-reachable + CLI-dispatch + JSC-VM-init
# code into a contiguous fault-around window instead of being interleaved
# with cold bun_bundler / bun_css / bun_shell code in fat-LTO emission order.
#
# Generated against the *release* (ICF'd) binary so the kept-representative
# names match what lld actually links — see -Wl,-icf=safe in flags.ts.
# Unknown symbols are silently ignored (paired with
# -Wl,--no-warn-symbol-ordering in flags.ts) so monomorphisation-hash
# changes in mangled names degrade gracefully. Regenerate when convenient:
#
#   for cmd in 'empty.js' '.' 'run hello' 'install --frozen-lockfile'; do
#     perf record -q -e instructions:u -c 3000 -- ./build/release/bun-profile $cmd
#     perf script -F ip,sym,dso | grep -F bun-profile')' | awk 'NF{print $2}'
#   done | awk '!seen[$0]++' >> src/startup.order
#
# (first-seen order — NOT `sort -u` — so call-order is preserved.)
#
# Order: .init_array targets -> mimalloc init -> main -> Rust CLI entry ->
# arg parse -> resolver/transpiler -> JSC VM init (JSC/WTF/ICU) -> teardown
# -> npm-script tail -> install tail.

