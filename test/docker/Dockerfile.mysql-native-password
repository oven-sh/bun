FROM mysql:8.4

# See Dockerfile.mysql-plain for the rationale. This variant pins mysql:8.4 and
# the mysql_native_password auth plugin to cover the legacy-auth code path.
# mysql_native_password was removed in MySQL 9.x, so 8.4 is the last LTS that
# ships it; 8.4 disables it by default and removed
# --default-authentication-plugin, so enable it and set it as the default
# first-factor via --authentication-policy instead.
ENV MYSQL_ROOT_PASSWORD=bun \
    MYSQL_DATABASE=bun_sql_test \
    MYSQL_ROOT_HOST=% \
    MYSQL_INITDB_SKIP_TZINFO=1

RUN set -e; \
    docker-entrypoint.sh mysqld \
        --datadir=/var/lib/mysql-init \
        --mysql-native-password=ON \
        --authentication-policy=mysql_native_password,, & pid=$!; \
    for i in $(seq 180); do \
        mysql -h127.0.0.1 -uroot -pbun -e 'SELECT 1' >/dev/null 2>&1 && break; \
        sleep 1; \
    done; \
    mysql -h127.0.0.1 -uroot -pbun -e 'SELECT 1'; \
    mysqladmin -h127.0.0.1 -uroot -pbun shutdown; \
    wait "$pid"

CMD ["mysqld", "--datadir=/var/lib/mysql-init", "--mysql-native-password=ON", "--authentication-policy=mysql_native_password,,"]
