FROM postgres:18
COPY init-scripts/postgres/ /docker-entrypoint-initdb.d/

# Bake a fully initialized data directory into the image so cold container
# start skips initdb + the temp-server init-script pass and is just
# `exec postgres` (~1-2s instead of ~5-8s). The postgres:18 base image declares
# `VOLUME /var/lib/postgresql`, which discards build-time writes under that
# path, so point PGDATA at a sibling outside it; the entrypoint reads PGDATA and
# sees it is already populated at runtime, so it goes straight to exec.
ENV POSTGRES_HOST_AUTH_METHOD=trust \
    POSTGRES_USER=postgres \
    PGDATA=/var/lib/pgdata-init

RUN set -e; \
    docker-entrypoint.sh postgres & pid=$!; \
    for i in $(seq 180); do \
        pg_isready -h 127.0.0.1 -U postgres >/dev/null 2>&1 && break; \
        sleep 1; \
    done; \
    pg_isready -h 127.0.0.1 -U postgres; \
    gosu postgres pg_ctl -D "$PGDATA" -m fast -w stop; \
    wait "$pid"
